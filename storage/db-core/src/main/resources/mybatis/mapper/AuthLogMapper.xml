<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ssafy.enjoytrip.storage.db.core.mybatis.mapper.AuthLogMapper">
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into auth_logs (user_id, event_type, logged_at) values (#{userId}, #{eventType}, current_timestamp)
    </insert>
</mapper>
