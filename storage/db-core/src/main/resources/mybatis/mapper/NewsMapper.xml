<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ssafy.enjoytrip.storage.db.core.mybatis.mapper.NewsMapper">
    <select id="findLatest" resultType="com.ssafy.enjoytrip.storage.db.core.model.NewsItemRecord">
        select id, title, link, summary, source, published_at as publishedAt
        from news_items
        order by created_at desc, id desc
        limit #{limit}
    </select>
</mapper>
