<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ssafy.enjoytrip.storage.db.core.mybatis.mapper.TagMapper">
    <select id="findAll" resultType="com.ssafy.enjoytrip.storage.db.core.model.TagRecord">
        select id, name from tags order by name asc
    </select>
    <select id="insert" resultType="com.ssafy.enjoytrip.storage.db.core.model.TagRecord">
        insert into tags (name) values (#{name})
        on conflict (name) do update set name = excluded.name
        returning id, name
    </select>
    <update id="update">
        update tags set name = #{name} where id = #{id}
    </update>
    <delete id="delete">
        delete from tags where id = #{id}
    </delete>
    <select id="countByIds" resultType="int">
        select count(*) from tags
        where id in
        <foreach collection="ids" item="id" open="(" separator="," close=")">#{id}</foreach>
    </select>
</mapper>
