<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <generator>
        <database>
            <name>org.jooq.meta.extensions.ddl.DDLDatabase</name>
            <properties>
                <property>
                    <key>scripts</key>
                    <value>build/jooq-ddl/*.sql</value>
                </property>
                <property>
                    <key>sort</key>
                    <value>semantic</value>
                </property>
                <property>
                    <key>unqualifiedSchema</key>
                    <value>none</value>
                </property>
                <property>
                    <key>defaultNameCase</key>
                    <value>lower</value>
                </property>
            </properties>
        </database>
        <target>
            <packageName>com.ssafy.enjoytrip.storage.db.core.jooq</packageName>
            <directory>build/generated-src/jooq/main</directory>
        </target>
    </generator>
</configuration>
