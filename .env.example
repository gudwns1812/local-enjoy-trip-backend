POSTGRES_DB=enjoytrip
POSTGRES_USER=ssafy
POSTGRES_PASSWORD=ssafy
POSTGRES_PORT=5432

PGADMIN_DEFAULT_EMAIL=admin@enjoytrip.local
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050

ENJOYTRIP_DB_URL=jdbc:postgresql://localhost:5432/enjoytrip
ENJOYTRIP_DB_USER=ssafy
ENJOYTRIP_DB_PASSWORD=ssafy
REDIS_URL=redis://localhost:6379/0

# Spring AI / GMS OpenAI-compatible neighborhood briefing
GMS_KEY=
GMS_CHAT_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com
GMS_CHAT_MODEL=gpt-5.4
GMS_BRIEFING_MAX_LENGTH=160

# Google OAuth login
# Google Cloud Console redirect URI: http://localhost:8080/login/oauth2/code/google
ENJOYTRIP_OAUTH2_GOOGLE_CLIENT_ID=
ENJOYTRIP_OAUTH2_GOOGLE_CLIENT_SECRET=
ENJOYTRIP_OAUTH2_REDIRECT_URI=http://localhost:5173/oauth/callback

# Local CDC / analytics stack (Postgres -> Debezium/Kafka Connect -> ClickHouse)
KAFKA_LOCAL_PORT=9092
KAFKA_CONNECT_PORT=8083
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_PASSWORD=enjoytrip_clickhouse
CDC_DB_USER=enjoytrip_cdc
CDC_DB_PASSWORD=enjoytrip_cdc
CDC_PUBLICATION_BOOTSTRAP_TIMEOUT_SECONDS=600

# Local tracing stack (OpenTelemetry Collector -> Grafana Tempo -> Grafana)
TEMPO_HTTP_PORT=13200
TEMPO_OTLP_GRPC_PORT=14317
TEMPO_OTLP_HTTP_PORT=14318
OTEL_COLLECTOR_OTLP_GRPC_PORT=4317
OTEL_COLLECTOR_OTLP_HTTP_PORT=4318
OTEL_COLLECTOR_PROMETHEUS_PORT=9464
PROMETHEUS_PORT=13090
GRAFANA_PORT=13002
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Local app tracing runtime values for the OpenTelemetry Java agent.
OTEL_SERVICE_NAME=enjoytrip-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none
