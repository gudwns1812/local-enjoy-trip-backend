## Copy this file to .env and replace every <...> placeholder before running locally.

POSTGRES_DB=enjoytrip
POSTGRES_USER=<local-db-user>
POSTGRES_PASSWORD=<local-db-password>
POSTGRES_PORT=5432

PGADMIN_DEFAULT_EMAIL=admin@enjoytrip.local
PGADMIN_DEFAULT_PASSWORD=<local-pgadmin-password>
PGADMIN_PORT=5050

ENJOYTRIP_DB_URL=<local-jdbc-url>
ENJOYTRIP_DB_USER=<local-db-user>
ENJOYTRIP_DB_PASSWORD=<local-db-password>
REDIS_URL=redis://localhost:6379/0

# Local MinIO object storage for Gotgot note images
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=<local-minio-user>
MINIO_ROOT_PASSWORD=<local-minio-password>
ENJOYTRIP_MINIO_ENDPOINT=http://localhost:19000
ENJOYTRIP_MINIO_BUCKET=gotgot-notes
ENJOYTRIP_MINIO_ACCESS_KEY=<local-minio-user>
ENJOYTRIP_MINIO_SECRET_KEY=<local-minio-password>
ENJOYTRIP_MINIO_REGION=ap-northeast-2
ENJOYTRIP_MINIO_PUBLIC_BASE_URL=http://localhost:19000/gotgot-notes
ENJOYTRIP_MINIO_UPLOAD_EXPIRY=10m

# Spring AI / GMS OpenAI-compatible neighborhood briefing
GMS_KEY=
GMS_CHAT_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com
GMS_CHAT_MODEL=gpt-4.1-nano
GMS_BRIEFING_MAX_LENGTH=120


# Google OAuth login
# Google Cloud Console redirect URI: http://localhost:8080/login/oauth2/code/google
ENJOYTRIP_OAUTH2_GOOGLE_CLIENT_ID=
ENJOYTRIP_OAUTH2_GOOGLE_CLIENT_SECRET=
ENJOYTRIP_OAUTH2_REDIRECT_URI=http://localhost:5173/oauth/callback
